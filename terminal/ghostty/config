command = /bin/zsh -l -c "tmux has-session -t main 2>/dev/null && tmux attach-session -t main || tmuxinator start main"

font-size = 11
window-decoration = true
macos-hidden = always

# quick terminal (§ to toggle)
keybind = global:§=toggle_quick_terminal
quick-terminal-position = right
quick-terminal-screen = mouse
quick-terminal-size = 75%
quick-terminal-animation-duration = 0
quick-terminal-autohide = true
